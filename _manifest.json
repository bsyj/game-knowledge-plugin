{
  "manifest_version": 2,
  "id": "bsyj.game-knowledge-plugin",
  "version": "1.0.4",
  "name": "GameKnowledge",
  "description": "Industrial-grade game knowledge analysis, storage, graph, and retrieval plugin for MaiBot.",
  "author": {
    "name": "bsyj",
    "url": "https://github.com/bsyj/game-knowledge-plugin"
  },
  "license": "GPL-3.0-or-later",
  "urls": {
    "repository": "https://github.com/bsyj/game-knowledge-plugin",
    "homepage": "https://github.com/bsyj/game-knowledge-plugin",
    "documentation": "https://github.com/bsyj/game-knowledge-plugin/blob/master/README.md",
    "issues": "https://github.com/bsyj/game-knowledge-plugin/issues"
  },
  "host_application": {
    "min_version": "1.0.0",
    "max_version": "1.99.99"
  },
  "sdk": {
    "min_version": "2.0.0",
    "max_version": "2.99.99"
  },
  "dependencies": [
    {"type": "python_package", "name": "numpy", "version_spec": ">=1.20.0"},
    {"type": "python_package", "name": "scipy", "version_spec": ">=1.7.0"},
    {"type": "python_package", "name": "networkx", "version_spec": ">=3.0.0"},
    {"type": "python_package", "name": "pyarrow", "version_spec": ">=10.0.0"},
    {"type": "python_package", "name": "pandas", "version_spec": ">=1.5.0"},
    {"type": "python_package", "name": "nest-asyncio", "version_spec": ">=1.5.0"},
    {"type": "python_package", "name": "faiss-cpu", "version_spec": ">=1.7.0"},
    {"type": "python_package", "name": "uvicorn", "version_spec": ">=0.20.0"},
    {"type": "python_package", "name": "pydantic", "version_spec": ">=2.0.0"},
    {"type": "python_package", "name": "python-multipart", "version_spec": ">=0.0.9"},
    {"type": "python_package", "name": "openai", "version_spec": ">=1.0.0"},
    {"type": "python_package", "name": "json-repair", "version_spec": ">=0.30.0"},
    {"type": "python_package", "name": "aiohttp", "version_spec": ">=3.8.0"},
    {"type": "python_package", "name": "psutil", "version_spec": ">=5.9.0"},
    {"type": "python_package", "name": "tomlkit", "version_spec": ">=0.12.0"},
    {"type": "python_package", "name": "rich", "version_spec": ">=14.0.0"},
    {"type": "python_package", "name": "tenacity", "version_spec": ">=8.0.0"},
    {"type": "python_package", "name": "jieba", "version_spec": ">=0.42.1"}
  ],
  "capabilities": [
    "send.text",
    "chat.get_stream_by_group_id",
    "llm.generate",
    "llm.embed",
    "message.get_by_time_in_chat",
    "message.build_readable",
    "component.get_all_plugins",
    "config.get",
    "database.query",
    "database.save",
    "database.get",
    "database.count",
    "database.delete"
  ],
  "i18n": {
    "default_locale": "zh-CN"
  }
}
